# DDNS client authentication (HTTP Basic Auth)
DDNS_USERNAME=udm
DDNS_PASSWORD=change-me

# Map incoming client hostname to one or more netcup records
# Format: client.fqdn=domain.tld:host,domain.tld:host;other.fqdn=example.org:@
# host '@' means zone apex, '*' means wildcard
DDNS_HOST_MAPPINGS=sub.example.com=example.com:sub

# Netcup API credentials (server-side only)
NETCUP_CUSTOMER_NUMBER=12345
NETCUP_API_KEY=replace-me
NETCUP_API_PASSWORD=replace-me

# Service settings
BIND_HOST=0.0.0.0
BIND_PORT=8000
LOG_LEVEL=INFO
