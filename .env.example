# ---------------------------------------------------------------------------
# ddns-netcup configuration
# Copy to `.env` and fill in. NEVER commit your real `.env`.
# ---------------------------------------------------------------------------

# --- Netcup API credentials (SERVER-SIDE ONLY, never sent to clients) ------
# Create an API key/password in the Netcup CCP under "Stammdaten > API".
NETCUP_CUSTOMER_NUMBER=123456
NETCUP_API_KEY=your_netcup_api_key
NETCUP_API_PASSWORD=your_netcup_api_password
# Optional override (defaults to the public CCP JSON endpoint):
# NETCUP_API_URL=https://ccp.netcup.net/run/webservice/servers/endpoint.php?JSON

# --- DDNS client authentication --------------------------------------------
# The credentials your router/DDNS client uses. These are NOT your Netcup login.
# Use Basic Auth (recommended for UniFi / inadyn):
DDNS_USERNAME=router
DDNS_PASSWORD=change-me-to-a-long-random-secret
# ...and/or a shared-secret token (sent as ?token=... or Bearer header):
# DDNS_TOKEN=another-long-random-secret

# --- What may be updated ----------------------------------------------------
# Comma-separated Netcup zones that are allowed to be written.
ALLOWED_DOMAINS=example.com
# Optional: restrict to specific FQDNs (comma-separated). Empty = any host
# inside ALLOWED_DOMAINS is permitted.
# ALLOWED_HOSTNAMES=home.example.com,vpn.example.com

# --- Address families -------------------------------------------------------
# Toggle A (IPv4) / AAAA (IPv6) updates. When a family is disabled the client
# may still send that IP — it is accepted but silently ignored (no DNS change).
# Useful e.g. to ignore the bogus IPv4 a dual-stack client sends.
ENABLE_IPV4=true
ENABLE_IPV6=true

# --- Server -----------------------------------------------------------------
PORT=8080
# Set to true ONLY when running behind a trusted reverse proxy (for correct
# client IP detection from X-Forwarded-For).
TRUST_PROXY=false
# debug | info | warn | error
LOG_LEVEL=info
